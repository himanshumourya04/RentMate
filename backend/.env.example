# Backend Environment Variables
# Copy this to .env and fill in your actual values

MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/rentmate?retryWrites=true&w=majority
JWT_SECRET=your_super_secret_jwt_key_here_must_be_long_random
PORT=5000

# Comma-separated list of allowed frontend origins (add your Vercel URL here after deploying)
CLIENT_URL=http://localhost:5173,https://your-app.vercel.app

# Firebase (for OTP during signup)
FIREBASE_PROJECT_ID=your_project_id
